<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface">

    <!-- Toolbar: app name + date subtitle + settings button -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:paddingTop="0dp"
        app:title="Cân Lúa"
        app:titleTextColor="@color/md_theme_onPrimary"
        app:subtitle=""
        app:subtitleTextColor="@color/md_theme_primaryContainer"
        app:navigationIcon="@drawable/ic_launcher_rice_scaled"
        app:navigationIconTint="@color/md_theme_onPrimary"
        android:background="@color/md_theme_primary"
        app:menu="@menu/menu_main" />

    <!-- Form card: customer + price + quick input (collapsed into 1 card) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_xs"
        app:cardCornerRadius="@dimen/corner_lg"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest"
        app:strokeWidth="1dp"
        app:strokeColor="@color/md_theme_outlineVariant">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm">

            <!-- Row 1: Customer name + Unit price -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:weightSum="10">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="6"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:hint="Tên khách hàng"
                    style="@style/Widget.Rice.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_customer_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/md_theme_onSurface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="4"
                    android:hint="Đơn giá"
                    style="@style/Widget.Rice.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_unit_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLines="1"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/md_theme_onSurface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Row 2: Quick input + Confirm button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:hint="Nhập nhanh (kg)"
                    app:endIconMode="clear_text"
                    style="@style/Widget.Rice.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_quick_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLength="7"
                        android:maxLines="1"
                        android:imeOptions="actionDone"
                        android:textSize="@dimen/text_title_sm"
                        android:textColor="@color/md_theme_onSurface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_confirm"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:minWidth="80dp"
                    android:text="Thêm"
                    android:textStyle="bold"
                    style="@style/Widget.Rice.Button.Primary" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Weight grid: RecyclerView with BOUNDED height — enables proper recycling -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_weights"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls" />

    <!-- Bottom totals + action bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/corner_lg"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/md_theme_primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm">

            <!-- Totals row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng khối lượng"
                        android:textColor="@color/md_theme_primaryContainer"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/tv_grand_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 kg"
                        android:textColor="@color/md_theme_onPrimary"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_title_sm" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/md_theme_primaryContainer"
                    android:alpha="0.4" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thành tiền"
                        android:textColor="@color/md_theme_primaryContainer"
                        android:textSize="@dimen/text_caption" />

                    <TextView
                        android:id="@+id/tv_total_money"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 VNĐ"
                        android:textColor="@color/md_theme_onPrimary"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_title_sm" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_lg"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:text="Lưu"
                    android:textStyle="bold"
                    app:backgroundTint="@color/md_theme_primaryContainer"
                    android:textColor="@color/md_theme_onPrimaryContainer"
                    style="@style/Widget.Rice.Button.Primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_lg"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="Xuất / Chia sẻ"
                    android:textStyle="bold"
                    app:backgroundTint="@color/md_theme_surfaceContainerLowest"
                    android:textColor="@color/md_theme_primary"
                    app:strokeColor="@color/md_theme_primaryContainer"
                    app:strokeWidth="1dp"
                    style="@style/Widget.Rice.Button.Primary" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
