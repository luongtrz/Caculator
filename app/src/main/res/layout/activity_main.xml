<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_sm">

            <!-- Date & Time Header -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/color_header_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thứ 5, ngày 26 tháng 12 năm 2024"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/color_header_text" />

                    <TextView
                        android:id="@+id/tv_lunar_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textSize="@dimen/text_body_sm"
                        android:textColor="#C8E6C9"
                        android:layout_marginTop="1dp" />

                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11:13:00 PM"
                        android:textSize="@dimen/text_body_lg"
                        android:textStyle="bold"
                        android:textColor="#C8E6C9"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Input Card (Name + Price) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_sm"
                    android:weightSum="10">

                    <!-- Customer Name (60%) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="6"
                        android:hint="Tên khách hàng"
                        app:boxStrokeColor="@color/md_theme_primary"
                        app:hintTextColor="@color/md_theme_primary"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        style="@style/Widget.Rice.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_customer_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textSize="@dimen/text_body_lg"
                            android:textStyle="bold"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Unit Price (40%) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="4"
                        android:hint="Đơn giá (VNĐ)"
                        app:boxStrokeColor="@color/md_theme_secondary"
                        app:hintTextColor="@color/md_theme_onSecondaryContainer"
                        style="@style/Widget.Rice.TextInputLayout">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_unit_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textSize="@dimen/text_body_lg"
                            android:textStyle="bold"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/md_theme_primaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/et_quick_input"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Nhập kg"
                        android:textColorHint="@color/md_theme_onSurfaceVariant"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"
                        android:textSize="@dimen/text_title_sm"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_onSurface"
                        android:maxLines="1"
                        android:maxLength="5"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md"
                        android:background="@drawable/bg_quick_input" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_confirm"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height_lg"
                        android:layout_weight="1"
                        android:text="OK"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold"
                        android:layout_marginStart="@dimen/spacing_sm"
                        style="@style/Widget.Rice.Button.Primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Weight Columns RecyclerView -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/md_theme_surfaceContainerLow">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_weights"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/spacing_sm"
                    android:clipToPadding="false" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Summary Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_gradient"
        android:padding="@dimen/spacing_md">

        <!-- Totals Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Grand Total -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng KL"
                    android:textSize="@dimen/text_body"
                    android:textColor="#C8E6C9"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_grand_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 kg"
                    android:textSize="@dimen/text_title_lg"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Total Money -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thành tiền"
                    android:textSize="@dimen/text_body"
                    android:textColor="#FFF9C4"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_total_money"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 VNĐ"
                    android:textSize="@dimen/text_title_lg"
                    android:textStyle="bold"
                    android:textColor="#FFD54F" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Lưu lại"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"
                style="@style/Widget.Rice.Button.Primary"
                app:backgroundTint="@color/white"
                android:textColor="@color/md_theme_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Chia sẻ"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold"
                android:layout_marginStart="6dp"
                style="@style/Widget.Rice.Button.Secondary"
                app:backgroundTint="#C8E6C9"
                android:textColor="@color/md_theme_onPrimaryContainer" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
