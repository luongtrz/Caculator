<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/corner_sm"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="1dp"
    app:strokeColor="@color/md_theme_outlineVariant"
    app:cardBackgroundColor="@color/md_theme_surfaceContainerLowest">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">

        <!-- Column Header -->
        <TextView
            android:id="@+id/tv_column_number"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:text="Cột 1"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:gravity="center"
            android:background="@drawable/bg_column_header"
            android:layout_marginBottom="3dp" />

        <!-- Bag 1 -->
        <TextView
            android:id="@+id/edit_weight_1"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:hint="0.0"
            android:textColorHint="@color/md_theme_outlineVariant"
            android:gravity="center"
            android:textSize="@dimen/weight_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:padding="4dp"
            android:background="@drawable/bg_weight_cell"
            android:layout_marginBottom="1dp"
            android:minHeight="@dimen/weight_cell_height"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Bag 2 -->
        <TextView
            android:id="@+id/edit_weight_2"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:hint="0.0"
            android:textColorHint="@color/md_theme_outlineVariant"
            android:gravity="center"
            android:textSize="@dimen/weight_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:padding="4dp"
            android:background="@drawable/bg_weight_cell"
            android:layout_marginBottom="1dp"
            android:minHeight="@dimen/weight_cell_height"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Bag 3 -->
        <TextView
            android:id="@+id/edit_weight_3"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:hint="0.0"
            android:textColorHint="@color/md_theme_outlineVariant"
            android:gravity="center"
            android:textSize="@dimen/weight_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:padding="4dp"
            android:background="@drawable/bg_weight_cell"
            android:layout_marginBottom="1dp"
            android:minHeight="@dimen/weight_cell_height"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Bag 4 -->
        <TextView
            android:id="@+id/edit_weight_4"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:hint="0.0"
            android:textColorHint="@color/md_theme_outlineVariant"
            android:gravity="center"
            android:textSize="@dimen/weight_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:padding="4dp"
            android:background="@drawable/bg_weight_cell"
            android:layout_marginBottom="1dp"
            android:minHeight="@dimen/weight_cell_height"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Bag 5 -->
        <TextView
            android:id="@+id/edit_weight_5"
            android:layout_width="@dimen/weight_cell_width"
            android:layout_height="wrap_content"
            android:hint="0.0"
            android:textColorHint="@color/md_theme_outlineVariant"
            android:gravity="center"
            android:textSize="@dimen/weight_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:padding="4dp"
            android:background="@drawable/bg_weight_cell"
            android:layout_marginBottom="1dp"
            android:minHeight="@dimen/weight_cell_height"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground" />

        <!-- Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/md_theme_primary"
            android:layout_marginVertical="3dp" />

        <!-- Column Total -->
        <TextView
            android:id="@+id/tv_column_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.0 kg"
            android:textSize="@dimen/weight_total_text_size"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimaryContainer"
            android:gravity="center"
            android:background="@drawable/bg_column_total" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
