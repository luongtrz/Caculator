<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">
    
    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ Cài đặt"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="16dp" />
    
    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />
    
    <!-- User Info Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tài khoản"
        android:textSize="12sp"
        android:textColor="#757575"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="20dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👤"
            android:textSize="32sp"
            android:layout_marginEnd="12dp" />
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            
            <TextView
                android:id="@+id/tv_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="14sp"
                android:textColor="#757575" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- Sync Status Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trạng thái đồng bộ"
        android:textSize="12sp"
        android:textColor="#757575"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="20dp">
        
        <!-- Sync Status Badge -->
        <View
            android:id="@+id/sync_status_badge"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@android:color/holo_green_dark"
            android:layout_marginEnd="8dp" />
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/tv_sync_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã đồng bộ"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121" />
            
            <TextView
                android:id="@+id/tv_sync_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả dữ liệu đã lưu trên cloud"
                android:textSize="12sp"
                android:textColor="#757575" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- Sign Out Button -->
    <Button
        android:id="@+id/btn_sign_out_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Đăng xuất"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#F44336"
        android:layout_marginTop="8dp" />
    
</LinearLayout>
