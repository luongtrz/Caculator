<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn định dạng xuất"
        android:textAppearance="@style/TextAppearance.Rice.TitleSmall"
        android:textColor="@color/md_theme_onSurface"
        android:gravity="center"
        android:paddingBottom="@dimen/spacing_lg" />

    <!-- Export as Image -->
    <LinearLayout
        android:id="@+id/btn_export_image"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="32sp"
            android:layout_marginEnd="@dimen/spacing_lg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu thành Ảnh (.jpg)"
                android:textAppearance="@style/TextAppearance.Rice.BodyLarge"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu vào thư mục Pictures"
                android:textAppearance="@style/TextAppearance.Rice.Caption"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginTop="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        android:layout_marginVertical="@dimen/spacing_sm" />

    <!-- Export as PDF -->
    <LinearLayout
        android:id="@+id/btn_export_pdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:padding="@dimen/spacing_lg"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📄"
            android:textSize="32sp"
            android:layout_marginEnd="@dimen/spacing_lg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu thành PDF (.pdf)"
                android:textAppearance="@style/TextAppearance.Rice.BodyLarge"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lưu vào thư mục Documents"
                android:textAppearance="@style/TextAppearance.Rice.Caption"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginTop="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
