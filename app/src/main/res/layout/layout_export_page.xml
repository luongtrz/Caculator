<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/export_bg"
    android:padding="24dp">
    
    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/tv_page_customer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khách hàng"
                android:textColor="@color/export_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/tv_page_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="26/12/2025 23:45"
                android:textColor="@color/export_text_primary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/tv_page_unit_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 VNĐ/kg"
            android:textColor="@color/export_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_gravity="center_vertical" />
    </LinearLayout>
    
    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/export_text_primary"
        android:layout_marginBottom="12dp" />
    
    <!-- Title -->
    <TextView
        android:id="@+id/tv_page_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PHIẾU CÂN - Trang 1/1"
        android:textColor="@color/export_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />
    
    <!-- Top Row (5 columns) -->
    <LinearLayout
        android:id="@+id/layout_top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp" />
    
    <!-- Bottom Row (5 columns) -->
    <LinearLayout
        android:id="@+id/layout_bottom_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp" />
    
    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/export_text_primary"
        android:layout_marginBottom="12dp" />
    
    <!-- Page Totals -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/export_totals_bg"
        android:padding="10dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng trang này:"
                android:textColor="@color/export_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/tv_page_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 kg"
                android:textColor="@color/export_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TỔNG CỘNG:"
                android:textColor="@color/export_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/tv_grand_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 kg"
                android:textColor="@color/export_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="THÀNH TIỀN:"
                android:textColor="@color/export_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/tv_total_money"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 VNĐ"
                android:textColor="@color/export_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- Signatures -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người giao"
                android:textColor="@color/export_text_primary"
                android:textSize="11sp"
                android:textStyle="italic" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Ký, ghi rõ họ tên)"
                android:textColor="@color/export_text_secondary"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người nhận"
                android:textColor="@color/export_text_primary"
                android:textSize="11sp"
                android:textStyle="italic" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Ký, ghi rõ họ tên)"
                android:textColor="@color/export_text_secondary"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
    
</LinearLayout>
