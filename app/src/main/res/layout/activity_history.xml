<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/color_header_bg"
            android:padding="@dimen/spacing_lg"
            android:elevation="4dp">

            <!-- Date & Time -->
            <TextView
                android:id="@+id/tv_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="03:12 PM, Thứ 7, 27/12/2025"
                android:textColor="@color/color_header_text"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_marginBottom="@dimen/spacing_xs" />

            <!-- Title and Settings Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lịch sử"
                    android:textColor="@color/color_header_text"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <!-- Settings Icon with Badge -->
                <FrameLayout
                    android:id="@+id/btn_settings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings_white"
                        app:tint="@color/color_header_text" />

                    <!-- Sync Status Badge -->
                    <View
                        android:id="@+id/sync_badge"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_sync_badge"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:visibility="visible" />
                </FrameLayout>
            </LinearLayout>

            <!-- Search Box -->
            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_search_bar"
                android:hint="Tìm theo tên khách hàng..."
                android:textColorHint="@color/md_theme_onSurfaceVariant"
                android:textColor="@color/md_theme_onSurface"
                android:singleLine="true"
                android:textSize="@dimen/text_body" />
        </LinearLayout>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="@dimen/spacing_sm"
            android:clipToPadding="false" />

        <!-- Add New Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_add_session"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:text="THÊM MỚI"
            android:textSize="@dimen/text_title_sm"
            android:textStyle="bold"
            style="@style/Widget.Rice.Button.Primary"
            android:layout_margin="@dimen/spacing_lg"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
