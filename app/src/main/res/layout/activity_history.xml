<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_history"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface">

    <!-- Toolbar: app icon + title + date subtitle + sync badge + settings -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_primary"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Lịch sử"
            app:titleTextColor="@color/md_theme_onPrimary"
            app:subtitle=""
            app:subtitleTextColor="@color/md_theme_primaryContainer"
            app:navigationIcon="@drawable/ic_launcher_rice_scaled"
            app:navigationIconTint="@color/md_theme_onPrimary"
            android:background="@color/md_theme_primary">

            <!-- Sync badge + Settings button inside toolbar -->
            <FrameLayout
                android:id="@+id/btn_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_settings_white"
                    android:tint="@color/md_theme_onPrimary"
                    android:contentDescription="Cài đặt" />

                <View
                    android:id="@+id/sync_badge"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_sync_badge"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp" />
            </FrameLayout>

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Search bar inside AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_sm"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_bar"
                android:hint="Tìm theo tên khách hàng..."
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:textColorHint="@color/md_theme_onSurfaceVariant"
                android:textColor="@color/md_theme_onSurface"
                android:singleLine="true"
                android:textSize="@dimen/text_body"
                android:imeOptions="actionSearch"
                android:inputType="textFilter" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Record list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <!-- Add new session button (full-width at bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/fab_add_session"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_lg"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:text="＋  Thêm mới"
        android:textSize="@dimen/text_body_lg"
        android:textStyle="bold"
        style="@style/Widget.Rice.Button.Primary" />

</LinearLayout>
