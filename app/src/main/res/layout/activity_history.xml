<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Rice.Card"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:id="@+id/tv_date_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="03:12 PM, Thứ 7, 27/12/2025"
                    android:textColor="@color/md_theme_onSurfaceVariant"
                    android:textSize="@dimen/text_body_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lịch sử"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />

                    <FrameLayout
                        android:id="@+id/btn_settings"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_weight_cell"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_settings_white"
                            app:tint="@color/md_theme_onSurface" />

                        <View
                            android:id="@+id/sync_badge"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_sync_badge"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="8dp"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:background="@drawable/bg_search_bar"
                    android:hint="Tìm theo tên khách hàng..."
                    android:paddingStart="@dimen/spacing_lg"
                    android:paddingEnd="@dimen/spacing_lg"
                    android:textColorHint="@color/md_theme_onSurfaceVariant"
                    android:textColor="@color/md_theme_onSurface"
                    android:singleLine="true"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="@dimen/spacing_sm"
            android:clipToPadding="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_add_session"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:text="Thêm mới"
            android:textSize="@dimen/text_body_lg"
            android:textStyle="bold"
            style="@style/Widget.Rice.Button.Primary"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconTint="@color/md_theme_onPrimary" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
