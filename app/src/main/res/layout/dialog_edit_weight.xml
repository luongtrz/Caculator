<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_lg"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/md_theme_surface"
    android:layout_margin="@dimen/spacing_xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <!-- Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chỉnh sửa giá trị"
                android:textAppearance="@style/TextAppearance.Rice.Title"
                android:textColor="@color/md_theme_primary" />
        </LinearLayout>

        <!-- Input field -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập giá trị (kg)"
            app:boxStrokeColor="@color/md_theme_primary"
            app:hintTextColor="@color/md_theme_primary"
            android:layout_marginBottom="@dimen/spacing_xl"
            style="@style/Widget.Rice.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_edit_weight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textSize="@dimen/text_title_lg"
                android:textColor="@color/md_theme_onSurface"
                android:textStyle="bold"
                android:padding="@dimen/spacing_lg" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_lg"
                android:layout_weight="1"
                android:text="HỦY"
                android:textSize="@dimen/text_body_lg"
                android:layout_marginEnd="@dimen/spacing_sm"
                style="@style/Widget.Rice.Button.Text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_lg"
                android:layout_weight="1"
                android:text="LƯU"
                android:textSize="@dimen/text_body_lg"
                android:layout_marginStart="@dimen/spacing_sm"
                style="@style/Widget.Rice.Button.Primary" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
