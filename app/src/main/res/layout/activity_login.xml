<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:gravity="center"
    android:padding="@dimen/spacing_xxl">

    <!-- App Logo -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_app_logo_rice"
        android:scaleType="centerInside"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:contentDescription="Logo" />

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ung Dung Can"
        android:textAppearance="@style/TextAppearance.Rice.Headline"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quan ly phieu can de dang"
        android:textAppearance="@style/TextAppearance.Rice.BodyLarge"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="48dp" />

    <!-- Welcome Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dang nhap de bat dau"
        android:textAppearance="@style/TextAppearance.Rice.TitleSmall"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="@dimen/spacing_xl" />

    <!-- Google Sign-in Button -->
    <com.google.android.gms.common.SignInButton
        android:id="@+id/btn_google_sign_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- Feature Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        app:cardCornerRadius="@dimen/corner_md"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/md_theme_surfaceContainerLow">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="- Du lieu duoc luu an toan tren cloud\n- Khong mat du lieu khi go ung dung\n- Hoat dong offline, tu dong dong bo"
            android:textAppearance="@style/TextAppearance.Rice.Body"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:padding="@dimen/spacing_lg" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
