<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:gravity="center"
    android:padding="32dp">
    
    <!-- App Logo/Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌾"
        android:textSize="80sp"
        android:layout_marginBottom="16dp" />
    
    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ứng Dụng Cân"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />
    
    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản lý phiếu cân dễ dàng"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="48dp" />
    
    <!-- Welcome Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng nhập để bắt đầu"
        android:textSize="18sp"
        android:textColor="#424242"
        android:layout_marginBottom="24dp" />
    
    <!-- Google Sign-in Button -->
    <com.google.android.gms.common.SignInButton
        android:id="@+id/btn_google_sign_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />
    
    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />
    
    <!-- Information Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="- Dữ liệu được lưu an toàn trên cloud\n- Không mất dữ liệu khi gỡ ứng dụng\n- Hoạt động offline, tự động đồng bộ"
        android:textSize="14sp"
        android:textColor="#616161"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="32dp" />
    
</LinearLayout>
